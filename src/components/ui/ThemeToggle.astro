---
/**
 * src/components/ui/ThemeToggle.astro
 *
 * Light/Dark theme toggle knop.
 *
 * - Leest opgeslagen theme uit localStorage bij page load.
 * - Schrijft data-theme op <html> element.
 * - Zero-flash: anti-flash script in BaseLayout laadt theme VOOR de eerste paint.
 * - ID-safe: gebruikt querySelector i.p.v. getElementById zodat meerdere
 *   instanties op de pagina niet elkaars IDs overschrijven.
 * - prefers-reduced-motion: transition uitgeschakeld als gevraagd.
 */
---

<button
    class="theme-toggle btn btn-ghost btn-icon"
    aria-label="Wissel licht/donker thema"
    title="Wissel thema"
    type="button"
    data-theme-toggle
>
    <!-- Zon — zichtbaar in dark mode (schakel naar light) -->
    <svg
        class="icon-theme icon-sun"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        style="flex-shrink:0"
    >
        <circle cx="12" cy="12" r="4"></circle>
        <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
        ></path>
    </svg>

    <!-- Maan — zichtbaar in light mode (schakel naar dark) -->
    <svg
        class="icon-theme icon-moon"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        style="flex-shrink:0"
    >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
</button>

<style>
    .theme-toggle {
        color: var(--color-muted);
        transition:
            color 0.15s ease,
            background 0.15s ease;
    }
    .theme-toggle:hover {
        color: var(--color-heading);
    }

    /* Icons: standaard verborgen via CSS, JS schakelt per theme */
    .icon-theme {
        display: none;
    }
    .icon-theme.is-visible {
        display: block;
    }

    @media (prefers-reduced-motion: reduce) {
        .theme-toggle {
            transition: none;
        }
    }
</style>

<script>
    (function () {
        // Gebruik data-attribuut i.p.v. id om collisions bij meerdere
        // instanties te voorkomen (bijv. header + mobile drawer)
        const buttons = document.querySelectorAll<HTMLButtonElement>(
            "[data-theme-toggle]",
        );

        function syncIcons(theme: string) {
            buttons.forEach((btn) => {
                const sun = btn.querySelector<SVGElement>(".icon-sun");
                const moon = btn.querySelector<SVGElement>(".icon-moon");
                if (!sun || !moon) return;
                // Dark → toon zon (om naar light te schakelen)
                sun.classList.toggle("is-visible", theme === "dark");
                // Light → toon maan (om naar dark te schakelen)
                moon.classList.toggle("is-visible", theme === "light");
                // Update aria-label dynamisch
                btn.setAttribute(
                    "aria-label",
                    theme === "dark"
                        ? "Schakel naar licht thema"
                        : "Schakel naar donker thema",
                );
            });
        }

        function getTheme(): string {
            const stored = localStorage.getItem("theme");
            if (stored === "light" || stored === "dark") return stored;
            // Lees het huidige data-theme (al gezet door BaseLayout anti-flash)
            return (
                document.documentElement.getAttribute("data-theme") ?? "dark"
            );
        }

        function setTheme(theme: string) {
            document.documentElement.setAttribute("data-theme", theme);
            localStorage.setItem("theme", theme);
            syncIcons(theme);
        }

        // Initieel synchroniseren
        syncIcons(getTheme());

        // Toggle op elke knop (werkt voor header én mobile drawer)
        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const current =
                    document.documentElement.getAttribute("data-theme") ??
                    "dark";
                setTheme(current === "dark" ? "light" : "dark");
            });
        });
    })();
</script>
