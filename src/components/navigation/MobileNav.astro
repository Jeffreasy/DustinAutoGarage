---
/**
 * src/components/navigation/MobileNav.astro
 *
 * Mobile menu drawer: slide-in panel van rechts, backdrop, gebruikersprofiel-
 * sectie, navigatielinks (SVG icons) en uitloggen onderaan.
 *
 * Zichtbaar: alleen op ≤ 640px.
 * z-index: --z-modal (500) — BOVEN header en dropdown.
 */

export interface Props {
    user: {
        full_name?: string | null;
        email?: string | null;
        role?: string;
    } | null;
    isAdmin: boolean;
    isActief: (pad: string) => boolean;
}

const { user, isAdmin, isActief } = Astro.props;

// Avatar initiaal + weergavenaam
const avatarInitiaal = (user?.full_name ?? user?.email ?? "U")
    .trim()
    .charAt(0)
    .toUpperCase();
const weergaveNaam = user?.full_name?.trim() || user?.email || "";
---

{user && (
    <div
        id="mobile-menu"
        class="mobile-menu"
        aria-hidden="true"
        role="dialog"
        aria-modal="true"
        aria-label="Navigatiemenu"
    >
        <!-- Backdrop overlay -->
        <div
            class="mobile-menu-backdrop"
            id="mobile-menu-backdrop"
            aria-hidden="true"
        />

        <!-- Drawer panel -->
        <div class="mobile-menu-panel" role="document">

            <!-- ── Header: titel + sluitknop ──────────────────── -->
            <div class="drawer-header">
                <div class="drawer-logo">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                        class="drawer-logo-icon"
                    >
                        <path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2" />
                        <circle cx="6.5" cy="16.5" r="2.5" />
                        <circle cx="16.5" cy="16.5" r="2.5" />
                    </svg>
                    <span>Menu</span>
                </div>
                <button
                    id="mobile-menu-close"
                    class="drawer-close-btn"
                    aria-label="Menu sluiten"
                    type="button"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            <!-- ── Profiel sectie ──────────────────────────── -->
            <a
                href="/medewerkers"
                class="drawer-profile"
                id="drawer-profile-link"
                aria-label={`Profiel van ${weergaveNaam} bekijken`}
            >
                <div class="drawer-profile-avatar" aria-hidden="true">
                    {avatarInitiaal}
                </div>
                <div class="drawer-profile-info">
                    <span class="drawer-profile-name">{weergaveNaam}</span>
                    <span class="drawer-profile-sub">Profiel & instellingen</span>
                </div>
                <!-- Pijl rechts -->
                <svg
                    class="drawer-profile-arrow"
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <polyline points="9 18 15 12 9 6" />
                </svg>
            </a>

            <!-- ── Navigatielinks ──────────────────────────── -->
            <nav class="drawer-nav" aria-label="Mobiele navigatie">

                <a href="/dashboard"
                    class:list={["drawer-nav-link", { "drawer-nav-link--actief": isActief("/dashboard") }]}
                >
                    <span class="drawer-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                        </svg>
                    </span>
                    Dashboard
                </a>

                <a href="/werkplaats"
                    class:list={["drawer-nav-link", { "drawer-nav-link--actief": isActief("/werkplaats") }]}
                >
                    <span class="drawer-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                        </svg>
                    </span>
                    Werkplaats
                </a>

                <a href="/klanten"
                    class:list={["drawer-nav-link", { "drawer-nav-link--actief": isActief("/klanten") }]}
                >
                    <span class="drawer-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </span>
                    Klanten
                </a>

                <a href="/voertuigen"
                    class:list={["drawer-nav-link", { "drawer-nav-link--actief": isActief("/voertuigen") }]}
                >
                    <span class="drawer-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/>
                        </svg>
                    </span>
                    Voertuigen
                </a>

                <a href="/onderhoud"
                    class:list={["drawer-nav-link", { "drawer-nav-link--actief": isActief("/onderhoud") }]}
                >
                    <span class="drawer-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/>
                        </svg>
                    </span>
                    Onderhoud
                </a>

                {isAdmin && (
                    <a href="/medewerkers"
                        class:list={["drawer-nav-link", { "drawer-nav-link--actief": isActief("/medewerkers") }]}
                    >
                        <span class="drawer-nav-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                        </span>
                        Medewerkers
                    </a>
                )}
            </nav>

            <!-- ── Footer: uitloggen ───────────────────────── -->
            <div class="drawer-footer">
                <a href="/logout" class="drawer-logout-btn" aria-label="Uitloggen">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Uitloggen
                </a>
            </div>

        </div>
    </div>
)}

<!-- Mobile menu open/close logica -->
<script>
    (function () {
        const toggle = document.getElementById("mobile-menu-toggle") as HTMLButtonElement | null;
        const menu = document.getElementById("mobile-menu");
        const closeBtn = document.getElementById("mobile-menu-close");
        const backdrop = document.getElementById("mobile-menu-backdrop");

        if (!toggle || !menu) return;

        function openMenu() {
            menu!.setAttribute("aria-hidden", "false");
            menu!.classList.add("mobile-menu--open");
            toggle!.setAttribute("aria-expanded", "true");
            toggle!.setAttribute("aria-label", "Menu sluiten");
            toggle!.classList.add("is-open");
            document.body.style.overflow = "hidden";
            // Focus sluiten-knop
            const closeBtnEl = document.getElementById("mobile-menu-close");
            if (closeBtnEl) setTimeout(() => closeBtnEl.focus(), 50);
        }

        function closeMenu() {
            menu!.setAttribute("aria-hidden", "true");
            menu!.classList.remove("mobile-menu--open");
            toggle!.setAttribute("aria-expanded", "false");
            toggle!.setAttribute("aria-label", "Menu openen");
            toggle!.classList.remove("is-open");
            document.body.style.overflow = "";
            toggle!.focus();
        }

        toggle.addEventListener("click", () => {
            menu.getAttribute("aria-hidden") === "false" ? closeMenu() : openMenu();
        });

        closeBtn?.addEventListener("click", closeMenu);
        backdrop?.addEventListener("click", closeMenu);

        // Escape
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && menu.getAttribute("aria-hidden") === "false") {
                closeMenu();
            }
        });

        // Sluit bij navigatie (links en profiel-knop)
        menu.querySelectorAll(".drawer-nav-link, .drawer-profile, .drawer-logout-btn").forEach((el) => {
            el.addEventListener("click", closeMenu);
        });
    })();
</script>

<style>
/* ═══════════════════════════════════════════════════════════════════
   MOBILE MENU DRAWER (zichtbaar op ≤ 640px)
   z-index: --z-modal (500)
   ═══════════════════════════════════════════════════════════════════ */
.mobile-menu {
    display: none; /* Desktop: verborgen */
    position: fixed;
    inset: 0;
    z-index: var(--z-modal); /* 500 */
    pointer-events: none;
}
.mobile-menu[aria-hidden="false"] {
    pointer-events: auto;
}

/* Backdrop */
.mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.3s ease;
}
.mobile-menu--open .mobile-menu-backdrop {
    opacity: 1;
}

/* Drawer panel */
.mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 88vw);
    background: var(--color-surface);
    border-left: 1px solid var(--glass-border, rgba(255, 255, 255, 0.06));
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    transform: translateX(105%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow:
        -8px 0 24px rgba(0, 0, 0, 0.3),
        -1px 0 0 rgba(255, 255, 255, 0.04);
}
.mobile-menu--open .mobile-menu-panel {
    transform: translateX(0);
}

/* ── Drawer header ────────────────────────────────────────────────── */
.drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border, rgba(255, 255, 255, 0.06));
    flex-shrink: 0;
    height: var(--header-height, 56px);
}

.drawer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-heading);
    font-family: var(--font-display);
}

.drawer-logo-icon {
    color: var(--color-accent);
    flex-shrink: 0;
}

.drawer-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--color-muted);
    transition:
        background 0.15s ease,
        color 0.15s ease,
        border-color 0.15s ease;
    flex-shrink: 0;
}
.drawer-close-btn:hover {
    background: var(--glass-bg, rgba(255, 255, 255, 0.06));
    color: var(--color-heading);
    border-color: var(--glass-border, rgba(255, 255, 255, 0.08));
}
.drawer-close-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
}

/* ── Profiel sectie ──────────────────────────────────────────────── */
.drawer-profile {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border, rgba(255, 255, 255, 0.06));
    text-decoration: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s ease;
}
.drawer-profile:hover {
    background: var(--glass-bg, rgba(255, 255, 255, 0.04));
}
.drawer-profile:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
}

.drawer-profile-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--color-accent, #14b8a6), #0d9488);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(20, 184, 166, 0.3);
    letter-spacing: var(--tracking-wider);
}

.drawer-profile-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.drawer-profile-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-heading);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: var(--leading-snug);
}

.drawer-profile-sub {
    font-size: var(--text-xs);
    color: var(--color-muted);
    line-height: var(--leading-snug);
}

.drawer-profile-arrow {
    color: var(--color-muted);
    flex-shrink: 0;
    transition: transform 0.15s ease;
}
.drawer-profile:hover .drawer-profile-arrow {
    transform: translateX(2px);
    color: var(--color-accent);
}

/* ── Navigatielinks in drawer ─────────────────────────────────────── */
.drawer-nav {
    display: flex;
    flex-direction: column;
    padding: var(--space-2) var(--space-3);
    flex: 1;
    gap: 2px;
    overflow-y: auto;
}

.drawer-nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-muted);
    text-decoration: none;
    cursor: pointer;
    transition:
        color 0.15s ease,
        background 0.15s ease;
    min-height: var(--control-height); /* 44px touch target */
}
.drawer-nav-link:hover {
    color: var(--color-heading);
    background: var(--glass-bg, rgba(255, 255, 255, 0.05));
}
.drawer-nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
}
.drawer-nav-link--actief {
    color: var(--color-heading);
    background: var(--glass-bg, rgba(255, 255, 255, 0.08));
    font-weight: var(--weight-semibold);
}

.drawer-nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    background: var(--glass-bg, rgba(255, 255, 255, 0.05));
    flex-shrink: 0;
    transition: background 0.15s ease;
}
.drawer-nav-link:hover .drawer-nav-icon,
.drawer-nav-link--actief .drawer-nav-icon {
    background: rgba(20, 184, 166, 0.1);
    color: var(--color-accent);
}
.drawer-nav-link--actief .drawer-nav-icon {
    color: var(--color-accent);
}

/* ── Drawer footer: uitloggen ─────────────────────────────────────── */
.drawer-footer {
    padding: var(--space-3) var(--space-3) calc(var(--space-5) + env(safe-area-inset-bottom, 0px));
    border-top: 1px solid var(--color-border, rgba(255, 255, 255, 0.06));
    flex-shrink: 0;
}

.drawer-logout-btn {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-muted);
    text-decoration: none;
    cursor: pointer;
    transition:
        background 0.15s ease,
        color 0.15s ease;
    min-height: var(--control-height); /* 44px touch target */
}
.drawer-logout-btn:hover {
    background: rgba(239, 68, 68, 0.08);
    color: var(--primitive-red-400, #f87171);
}
.drawer-logout-btn:focus-visible {
    outline: 2px solid var(--primitive-red-400, #f87171);
    outline-offset: 2px;
}
.drawer-logout-btn svg {
    flex-shrink: 0;
}

/* ── Toon drawer alleen op mobiel ─────────────────────────────────── */
@media (max-width: 640px) {
    .mobile-menu {
        display: block;
    }
}

/* Accessibility: reduced motion */
@media (prefers-reduced-motion: reduce) {
    .mobile-menu-panel,
    .mobile-menu-backdrop,
    .drawer-profile-arrow {
        transition: none;
    }
}
</style>
