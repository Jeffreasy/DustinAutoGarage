---
/**
 * src/layouts/BaseLayout.astro
 *
 * Root layout voor alle pagina's.
 * Bevat de ENIGE navigatiebalk van de app + footer.
 * Pages bevatten GEEN eigen <header> meer.
 *
 * Props:
 *   title       — paginatitel
 *   description — meta-description (SEO)
 */

import SiteHeader from "../components/navigation/SiteHeader.astro";
import MobileNav from "../components/navigation/MobileNav.astro";
import SiteFooter from "../components/footer/SiteFooter.astro";

import "../styles/design-tokens.css";
import "../styles/typography.css";
import "../styles/spacing.css";
import "../styles/components.css";
import "../styles/utilities.css";

export interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Dustin Auto Garage — Professioneel klanten- en voertuigbeheer",
} = Astro.props;

const user = Astro.locals.user;
const isAdmin = user?.role === "editor" || user?.role === "admin";

// Actieve pagina voor nav highlight
const huidigeUrl = Astro.url.pathname;
const isActief = (pad: string) =>
    pad === "/" ? huidigeUrl === pad : huidigeUrl.startsWith(pad);
---

<!doctype html>
<html lang="nl" data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#07090f" id="meta-theme-color" />
        <title>{title} — Dustin Auto Garage</title>

        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Anti-flash theme script: uitgevoerd VOOR de eerste render -->
        <script is:inline>
            (function () {
                var stored = localStorage.getItem("theme");
                var preferred = window.matchMedia(
                    "(prefers-color-scheme: light)",
                ).matches
                    ? "light"
                    : "dark";
                var theme =
                    stored === "light" || stored === "dark"
                        ? stored
                        : preferred;
                document.documentElement.setAttribute("data-theme", theme);
                var meta = document.getElementById("meta-theme-color");
                if (meta)
                    meta.setAttribute(
                        "content",
                        theme === "light" ? "#eef1f5" : "#07090f",
                    );
            })();
        </script>

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@400;700&display=swap"
            rel="stylesheet"
        />
    </head>

    <body>
        <!-- Skip-link: eerste element in body voor screenreaders -->
        <a href="#main-content" class="skip-link sr-only focus-ring">
            Ga naar inhoud
        </a>

        <!-- ── Site header (desktop nav + hamburger) ──────────────────────── -->
        <SiteHeader {user} {isAdmin} {isActief} />

        <!-- ── Mobile drawer ──────────────────────────────────────────────── -->
        <MobileNav {user} {isAdmin} {isActief} />

        <!-- ── Page content ───────────────────────────────────────────────── -->
        <main role="main" id="main-content" class="page-main">
            <slot />
        </main>

        <!-- ── Footer ─────────────────────────────────────────────────────── -->
        <SiteFooter {user} {isAdmin} {isActief} />

        <!-- Theme-toggle meta-sync -->
        <script>
            const metaTheme = document.getElementById(
                "meta-theme-color",
            ) as HTMLMetaElement | null;
            const observer = new MutationObserver(() => {
                const theme =
                    document.documentElement.getAttribute("data-theme");
                if (metaTheme)
                    metaTheme.content =
                        theme === "light" ? "#eef1f5" : "#07090f";
            });
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["data-theme"],
            });
        </script>
    </body>
</html>

<style>
    /* ── Skip-link ────────────────────────────────────────────────────────── */
    .skip-link {
        position: fixed;
        top: var(--space-2);
        left: var(--space-2);
        z-index: 9999;
        background: var(--color-accent);
        color: var(--color-on-accent);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-md);
        font-weight: var(--weight-medium);
        text-decoration: none;
    }

    /* ── Page main ────────────────────────────────────────────────────────── */
    .page-main {
        min-height: calc(100vh - 60px - 80px); /* viewport - header - footer */
    }
</style>
