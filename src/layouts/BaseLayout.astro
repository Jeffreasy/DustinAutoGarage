---
/**
 * src/layouts/BaseLayout.astro
 *
 * Root layout voor alle pagina's.
 * Bevat de ENIGE navigatiebalk van de app + footer.
 * Pages bevatten GEEN eigen <header> meer.
 *
 * Props:
 *   title       — paginatitel
 *   description — meta-description (SEO)
 */

import ThemeToggle from "../components/ThemeToggle.astro";

import "../styles/design-tokens.css";
import "../styles/typography.css";
import "../styles/spacing.css";
import "../styles/components.css";
import "../styles/utilities.css";

export interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Dustin Auto Garage — Professioneel klanten- en voertuigbeheer",
} = Astro.props;

const user = Astro.locals.user;
const isAdmin = user?.role === "editor" || user?.role === "admin";

// Actieve pagina voor nav highlight
const huidigeUrl = Astro.url.pathname;
const isActief = (pad: string) =>
    pad === "/" ? huidigeUrl === pad : huidigeUrl.startsWith(pad);
---

<!doctype html>
<html lang="nl" data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#07090f" id="meta-theme-color" />
        <title>{title} — Dustin Auto Garage</title>

        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Anti-flash theme script: uitgevoerd VOOR de eerste render -->
        <script is:inline>
            (function () {
                var stored = localStorage.getItem("theme");
                var preferred = window.matchMedia(
                    "(prefers-color-scheme: light)",
                ).matches
                    ? "light"
                    : "dark";
                var theme =
                    stored === "light" || stored === "dark"
                        ? stored
                        : preferred;
                document.documentElement.setAttribute("data-theme", theme);
                var meta = document.getElementById("meta-theme-color");
                if (meta)
                    meta.setAttribute(
                        "content",
                        theme === "light" ? "#f8fafc" : "#07090f",
                    );
            })();
        </script>

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@400;700&display=swap"
            rel="stylesheet"
        />
    </head>

    <body>
        <!-- Skip-link moet EERSTE element in body zijn voor screenreaders -->
        <a
            href="#main-content"
            class="skip-link sr-only focus-ring"
        >
            Ga naar inhoud
        </a>

        <!-- ── Navigatiebalk (ENIGE nav in de app) ───────────────────────── -->
        <header class="site-header no-print" role="banner">
            <div class="site-header-inner">
                <!-- Logo / Brand -->
                <a
                    href="/dashboard"
                    class="site-logo"
                    aria-label="Dustin Auto Garage — Dashboard"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                        style="color: var(--color-accent);"
                    >
                        <path
                            d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"
                        ></path>
                        <circle cx="6.5" cy="16.5" r="2.5"></circle>
                        <circle cx="16.5" cy="16.5" r="2.5"></circle>
                    </svg>
                    <span>Dustin Auto Garage</span>
                </a>

                <!-- Navigatielinks — zichtbaar als ingelogd (desktop only) -->
                {
                    user && (
                        <nav
                            class="site-nav hide-mobile"
                            aria-label="Hoofdnavigatie"
                        >
                            <a
                                href="/dashboard"
                                class:list={[
                                    "nav-link",
                                    {
                                        "nav-link--actief":
                                            isActief("/dashboard"),
                                    },
                                ]}
                            >
                                Dashboard
                            </a>
                            <a
                                href="/werkplaats"
                                class:list={[
                                    "nav-link",
                                    {
                                        "nav-link--actief":
                                            isActief("/werkplaats"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">🏭</span> Werkplaats
                            </a>
                            <a
                                href="/klanten"
                                class:list={[
                                    "nav-link",
                                    {
                                        "nav-link--actief":
                                            isActief("/klanten"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">👥</span> Klanten
                            </a>
                            <a
                                href="/voertuigen"
                                class:list={[
                                    "nav-link",
                                    {
                                        "nav-link--actief":
                                            isActief("/voertuigen"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">🚗</span> Voertuigen
                            </a>
                            <a
                                href="/onderhoud"
                                class:list={[
                                    "nav-link",
                                    {
                                        "nav-link--actief":
                                            isActief("/onderhoud"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">🔧</span> Onderhoud
                            </a>
                            {isAdmin && (
                                <a
                                    href="/medewerkers"
                                    class:list={[
                                        "nav-link",
                                        {
                                            "nav-link--actief":
                                                isActief("/medewerkers"),
                                        },
                                    ]}
                                >
                                    <span aria-hidden="true">👥</span>{" "}
                                    Medewerkers
                                </a>
                            )}
                        </nav>
                    )
                }

                <!-- Acties rechts -->
                <div class="site-header-actions">
                    {
                        user && (
                            <span
                                class="nav-user-name hide-mobile"
                                title={user.email ?? ""}
                            >
                                {user.full_name ?? user.email}
                            </span>
                        )
                    }
                    <ThemeToggle />
                    {
                        user && (
                            <a
                                href="/logout"
                                class="btn btn-ghost btn-sm no-print hide-mobile"
                                aria-label="Uitloggen"
                            >
                                Uitloggen
                            </a>
                        )
                    }

                    <!-- Hamburger toggle — uitsluitend mobiel zichtbaar -->
                    {
                        user && (
                            <button
                                id="mobile-menu-toggle"
                                class="mobile-menu-btn show-mobile"
                                aria-label="Menu openen"
                                aria-expanded="false"
                                aria-controls="mobile-menu"
                                type="button"
                            >
                                <span class="hamburger-line"></span>
                                <span class="hamburger-line"></span>
                                <span class="hamburger-line"></span>
                            </button>
                        )
                    }
                </div>
            </div>
        </header>

        <!-- ── Mobile menu drawer ────────────────────────────────────────── -->
        {
            user && (
                <div
                    id="mobile-menu"
                    class="mobile-menu"
                    aria-hidden="true"
                    role="dialog"
                    aria-modal="true"
                    aria-label="Navigatiemenu"
                >
                    <!-- Backdrop / overlay -->
                    <div class="mobile-menu-backdrop" id="mobile-menu-backdrop" />

                    <!-- Drawer panel -->
                    <div class="mobile-menu-panel">
                        <!-- Drawer header -->
                        <div class="mobile-menu-header">
                            <span class="mobile-menu-title">Menu</span>
                            <button
                                id="mobile-menu-close"
                                class="mobile-menu-close"
                                aria-label="Menu sluiten"
                                type="button"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                >
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                            </button>
                        </div>

                        <!-- Gebruikersinfo -->
                        {user && (
                            <div class="mobile-menu-user">
                                <span class="mobile-user-name">
                                    {user.full_name ?? user.email}
                                </span>
                                <span class="mobile-user-email">
                                    {user.email}
                                </span>
                            </div>
                        )}

                        <!-- Navigatielinks -->
                        <nav
                            class="mobile-nav"
                            aria-label="Mobiele navigatie"
                        >
                            <a
                                href="/dashboard"
                                class:list={[
                                    "mobile-nav-link",
                                    {
                                        "mobile-nav-link--actief":
                                            isActief("/dashboard"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">📊</span>
                                Dashboard
                            </a>
                            <a
                                href="/werkplaats"
                                class:list={[
                                    "mobile-nav-link",
                                    {
                                        "mobile-nav-link--actief":
                                            isActief("/werkplaats"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">🏭</span>
                                Werkplaats
                            </a>
                            <a
                                href="/klanten"
                                class:list={[
                                    "mobile-nav-link",
                                    {
                                        "mobile-nav-link--actief":
                                            isActief("/klanten"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">👥</span>
                                Klanten
                            </a>
                            <a
                                href="/voertuigen"
                                class:list={[
                                    "mobile-nav-link",
                                    {
                                        "mobile-nav-link--actief":
                                            isActief("/voertuigen"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">🚗</span>
                                Voertuigen
                            </a>
                            <a
                                href="/onderhoud"
                                class:list={[
                                    "mobile-nav-link",
                                    {
                                        "mobile-nav-link--actief":
                                            isActief("/onderhoud"),
                                    },
                                ]}
                            >
                                <span aria-hidden="true">🔧</span>
                                Onderhoud
                            </a>
                            {isAdmin && (
                                <a
                                    href="/medewerkers"
                                    class:list={[
                                        "mobile-nav-link",
                                        {
                                            "mobile-nav-link--actief":
                                                isActief("/medewerkers"),
                                        },
                                    ]}
                                >
                                    <span aria-hidden="true">🛡️</span>
                                    Medewerkers
                                </a>
                            )}
                        </nav>

                        <!-- Uitloggen onderaan drawer -->
                        <div class="mobile-menu-footer">
                            <a
                                href="/logout"
                                class="mobile-logout-btn"
                                aria-label="Uitloggen"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                >
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                    <polyline points="16 17 21 12 16 7" />
                                    <line x1="21" y1="12" x2="9" y2="12" />
                                </svg>
                                Uitloggen
                            </a>
                        </div>
                    </div>
                </div>
            )
        }

        <!-- ── Page content ─────────────────────────────────────────────── -->
        <main role="main" id="main-content" class="page-main">
            <slot />
        </main>

        <!-- ── Footer ───────────────────────────────────────────────────── -->
        <footer class="site-footer no-print" role="contentinfo">
            <div class="site-footer-inner">
                <div class="footer-brand">
                    <span class="footer-logo-text">Dustin Auto Garage</span>
                    <span class="footer-tagline"
                        >Professioneel klanten- en voertuigbeheer</span
                    >
                </div>

                {
                    user && (
                        <nav class="footer-nav" aria-label="Footernavigatie">
                            <a
                                href="/dashboard"
                                class:list={[
                                    "footer-link",
                                    { "footer-link--actief": isActief("/dashboard") },
                                ]}
                            >
                                Dashboard
                            </a>
                            <a
                                href="/werkplaats"
                                class:list={[
                                    "footer-link",
                                    { "footer-link--actief": isActief("/werkplaats") },
                                ]}
                            >
                                Werkplaats
                            </a>
                            <a
                                href="/klanten"
                                class:list={[
                                    "footer-link",
                                    { "footer-link--actief": isActief("/klanten") },
                                ]}
                            >
                                Klanten
                            </a>
                            <a
                                href="/voertuigen"
                                class:list={[
                                    "footer-link",
                                    { "footer-link--actief": isActief("/voertuigen") },
                                ]}
                            >
                                Voertuigen
                            </a>
                            <a
                                href="/onderhoud"
                                class:list={[
                                    "footer-link",
                                    { "footer-link--actief": isActief("/onderhoud") },
                                ]}
                            >
                                Onderhoud
                            </a>
                            {isAdmin && (
                                <a
                                    href="/medewerkers"
                                    class:list={[
                                        "footer-link",
                                        {
                                            "footer-link--actief":
                                                isActief("/medewerkers"),
                                        },
                                    ]}
                                >
                                    Medewerkers
                                </a>
                            )}
                        </nav>
                    )
                }

                <p class="footer-copy">
                    &copy; {new Date().getFullYear()} Dustin Auto Garage
                </p>
            </div>
        </footer>

        <!-- Theme-toggle meta-sync -->
        <script>
            const metaTheme = document.getElementById(
                "meta-theme-color",
            ) as HTMLMetaElement | null;
            const observer = new MutationObserver(() => {
                const theme =
                    document.documentElement.getAttribute("data-theme");
                if (metaTheme)
                    metaTheme.content =
                        theme === "light" ? "#f8fafc" : "#07090f";
            });
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["data-theme"],
            });
        </script>

        <!-- Mobile menu logic -->
        <script>
            (function () {
                const toggle = document.getElementById("mobile-menu-toggle");
                const menu = document.getElementById("mobile-menu");
                const closeBtn = document.getElementById("mobile-menu-close");
                const backdrop = document.getElementById("mobile-menu-backdrop");

                if (!toggle || !menu) return;

                function openMenu() {
                    menu!.setAttribute("aria-hidden", "false");
                    menu!.classList.add("mobile-menu--open");
                    toggle!.setAttribute("aria-expanded", "true");
                    toggle!.setAttribute("aria-label", "Menu sluiten");
                    toggle!.classList.add("is-open");
                    document.body.style.overflow = "hidden";
                    // Focus eerste link in menu
                    const firstLink = menu!.querySelector<HTMLElement>(".mobile-nav-link");
                    if (firstLink) setTimeout(() => firstLink.focus(), 50);
                }

                function closeMenu() {
                    menu!.setAttribute("aria-hidden", "true");
                    menu!.classList.remove("mobile-menu--open");
                    toggle!.setAttribute("aria-expanded", "false");
                    toggle!.setAttribute("aria-label", "Menu openen");
                    toggle!.classList.remove("is-open");
                    document.body.style.overflow = "";
                    toggle!.focus();
                }

                toggle.addEventListener("click", () => {
                    const isOpen = menu.getAttribute("aria-hidden") === "false";
                    isOpen ? closeMenu() : openMenu();
                });

                closeBtn?.addEventListener("click", closeMenu);
                backdrop?.addEventListener("click", closeMenu);

                // Escape key
                document.addEventListener("keydown", (e) => {
                    if (e.key === "Escape" && menu.getAttribute("aria-hidden") === "false") {
                        closeMenu();
                    }
                });

                // Sluit menu bij navigatie (zelfde pagina reload of link click)
                menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
                    link.addEventListener("click", closeMenu);
                });
            })();
        </script>
    </body>
</html>

<style>
    /* ── Skip-link ────────────────────────────────────────────────────────── */
    .skip-link {
        position: fixed;
        top: var(--space-2);
        left: var(--space-2);
        z-index: 9999;
        background: var(--color-accent);
        color: var(--color-on-accent);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-md);
        font-weight: var(--weight-medium);
        text-decoration: none;
    }

    /* ── Site-header ──────────────────────────────────────────────────────── */
    .site-header {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky, 100);
        background: var(--glass-bg-strong, var(--color-surface));
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--glass-border, var(--color-border));
        box-shadow: 0 1px 0 var(--glass-border, var(--color-border));
    }

    .site-header-inner {
        max-width: var(--container-max, 1280px);
        margin: 0 auto;
        padding: 0 var(--space-5);
        height: 60px;
        display: flex;
        align-items: center;
        gap: var(--space-6);
    }

    .site-logo {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-weight: var(--weight-bold);
        font-size: var(--text-sm);
        color: var(--color-heading);
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        transition: opacity var(--transition-base);
    }
    .site-logo:hover {
        opacity: 0.8;
    }

    /* ── Navigatielinks (desktop) ────────────────────────────────────────── */
    .site-nav {
        display: flex;
        align-items: center;
        gap: var(--space-1);
        flex: 1;
    }

    .nav-link {
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        color: var(--color-muted);
        text-decoration: none;
        transition:
            color var(--transition-base),
            background var(--transition-base);
        white-space: nowrap;
    }
    .nav-link:hover {
        color: var(--color-heading);
        background: var(--glass-bg, rgba(255, 255, 255, 0.05));
    }
    .nav-link--actief {
        color: var(--color-heading);
        background: var(--glass-bg, rgba(255, 255, 255, 0.08));
        font-weight: var(--weight-semibold);
    }

    /* ── Acties rechts ───────────────────────────────────────────────────── */
    .site-header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        margin-left: auto;
        flex-shrink: 0;
    }

    .nav-user-name {
        font-size: var(--text-xs);
        color: var(--color-muted);
        max-width: 160px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ── Hamburger knop ──────────────────────────────────────────────────── */
    .mobile-menu-btn {
        display: none; /* standaard verborgen, show-mobile toont het */
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        padding: var(--space-2);
        background: transparent;
        border: 1px solid var(--glass-border, var(--color-border));
        border-radius: var(--radius-md);
        cursor: pointer;
        color: var(--color-heading);
        transition: background var(--transition-base), border-color var(--transition-base);
        flex-shrink: 0;
    }
    .mobile-menu-btn:hover {
        background: var(--glass-bg, rgba(255, 255, 255, 0.05));
    }

    .hamburger-line {
        display: block;
        width: 18px;
        height: 2px;
        background: currentColor;
        border-radius: 2px;
        transition: transform 0.25s ease, opacity 0.25s ease;
        transform-origin: center;
    }

    /* Hamburger → X animatie */
    .mobile-menu-btn.is-open .hamburger-line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }
    .mobile-menu-btn.is-open .hamburger-line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }
    .mobile-menu-btn.is-open .hamburger-line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* ── Mobile menu drawer ──────────────────────────────────────────────── */
    .mobile-menu {
        display: none; /* verborgen op desktop */
        position: fixed;
        inset: 0;
        z-index: var(--z-modal, 200);
        pointer-events: none;
    }
    .mobile-menu[aria-hidden="false"] {
        pointer-events: auto;
    }

    .mobile-menu-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .mobile-menu--open .mobile-menu-backdrop {
        opacity: 1;
    }

    .mobile-menu-panel {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        width: min(300px, 85vw);
        background: var(--color-surface);
        border-left: 1px solid var(--glass-border, var(--color-border));
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: -4px 0 24px rgba(0, 0, 0, 0.3);
        overflow-y: auto;
    }
    .mobile-menu--open .mobile-menu-panel {
        transform: translateX(0);
    }

    .mobile-menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-4) var(--space-5);
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }

    .mobile-menu-title {
        font-size: var(--text-base);
        font-weight: var(--weight-semibold);
        color: var(--color-heading);
    }

    .mobile-menu-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: transparent;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        color: var(--color-muted);
        transition: background var(--transition-base), color var(--transition-base);
    }
    .mobile-menu-close:hover {
        background: var(--glass-bg, rgba(255, 255, 255, 0.05));
        color: var(--color-heading);
    }

    /* Gebruikersinfo in drawer */
    .mobile-menu-user {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: var(--space-4) var(--space-5);
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }
    .mobile-user-name {
        font-size: var(--text-sm);
        font-weight: var(--weight-semibold);
        color: var(--color-heading);
    }
    .mobile-user-email {
        font-size: var(--text-xs);
        color: var(--color-muted);
        overflow: hidden;
        text-overflow: ellipsis;
