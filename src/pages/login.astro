---
/**
 * src/pages/login.astro
 *
 * Publieke login pagina — authenticeert via de lokale BFF proxy.
 * De proxy (/api/auth/login) stuurt het request door naar LaventeCare
 * en sanitizeert de Set-Cookie headers voor localhost.
 *
 * Design System: alle waarden bouwen op design-tokens.css.
 */

import "../styles/design-tokens.css";
import "../styles/typography.css";
import "../styles/components.css";
---

<!doctype html>
<html lang="nl" data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Inloggen — Dustin Auto Garage</title>

        <!-- Anti-flash: zet theme VOOR eerste paint -->
        <script is:inline>
            (function () {
                var stored = localStorage.getItem("theme");
                var preferred = window.matchMedia(
                    "(prefers-color-scheme: light)",
                ).matches
                    ? "light"
                    : "dark";
                var theme =
                    stored === "light" || stored === "dark"
                        ? stored
                        : preferred;
                document.documentElement.setAttribute("data-theme", theme);
            })();
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@400;700&display=swap"
            rel="stylesheet"
        />

        <style>
            body {
                font-family: var(--font-sans);
                background-color: var(--color-bg);
                color: var(--color-body);
                min-height: 100svh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: var(--space-4);
                transition:
                    background-color var(--transition-slow),
                    color var(--transition-slow);
            }

            .login-card {
                background: var(--glass-bg);
                backdrop-filter: blur(20px) saturate(180%);
                -webkit-backdrop-filter: blur(20px) saturate(180%);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-2xl);
                padding: var(--space-8) var(--space-8);
                width: 100%;
                max-width: var(--card-max-width-sm);
                box-shadow: var(--glass-shadow), var(--shadow-xl);
                position: relative;
                overflow: hidden;
            }

            /* Top glare accent lijn */
            .login-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(
                    90deg,
                    transparent 0%,
                    var(--color-border-luminous) 30%,
                    var(--color-accent) 50%,
                    var(--color-border-luminous) 70%,
                    transparent 100%
                );
                pointer-events: none;
            }

            .login-logo {
                font-size: var(--text-lg);
                font-weight: var(--weight-bold);
                color: var(--color-heading);
                margin-bottom: var(--space-1);
                display: flex;
                align-items: center;
                gap: var(--space-2);
            }

            .login-subtitle {
                font-size: var(--text-sm);
                color: var(--color-muted);
                margin-bottom: var(--space-6);
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: var(--space-1);
                margin-bottom: var(--space-4);
            }

            label {
                font-size: var(--text-xs);
                font-weight: var(--weight-medium);
                color: var(--color-body);
                letter-spacing: var(--tracking-wide);
                text-transform: uppercase;
            }

            input[type="email"],
            input[type="password"],
            input[type="text"] {
                width: 100%;
                padding: var(--space-2) var(--space-3);
                background: var(--glass-bg-subtle);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                border: 1px solid var(--glass-border);
                border-radius: var(--radius-md);
                color: var(--color-heading);
                font-size: var(--text-sm);
                font-family: var(--font-sans);
                min-height: var(--control-height);
                transition:
                    border-color var(--transition-fast),
                    box-shadow var(--transition-fast),
                    background-color var(--transition-fast);
                outline: none;
            }

            input::placeholder {
                color: var(--color-muted);
            }

            input:hover:not(:disabled) {
                border-color: var(--color-border-hover);
            }

            input:focus {
                border-color: var(--color-border-focus);
                box-shadow: var(--focus-ring);
                background: var(--color-surface);
            }

            .btn-login {
                width: 100%;
                padding: var(--space-3) var(--space-4);
                background: var(--gradient-accent);
                color: var(--color-on-accent);
                font-weight: var(--weight-semibold);
                font-size: var(--text-sm);
                font-family: var(--font-sans);
                border: 1px solid transparent;
                border-radius: var(--radius-md);
                cursor: pointer;
                min-height: var(--control-height);
                box-shadow: var(--shadow-glow-sm);
                transition:
                    background var(--transition-fast),
                    box-shadow var(--transition-fast),
                    transform var(--transition-fast);
            }

            .btn-login:hover:not(:disabled) {
                background: var(--gradient-accent-hover);
                box-shadow: var(--shadow-glow);
                transform: translateY(-1px);
            }

            .btn-login:active {
                transform: translateY(0);
                box-shadow: var(--shadow-glow-sm);
            }

            .btn-login:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

            .error-box {
                display: none;
                background: var(--color-error-bg);
                border: 1px solid var(--color-error-border);
                color: var(--color-error);
                border-radius: var(--radius-md);
                padding: var(--space-3) var(--space-4);
                font-size: var(--text-sm);
                margin-bottom: var(--space-4);
            }

            .error-box.visible {
                display: block;
            }

            .mfa-hint {
                font-size: var(--text-sm);
                color: var(--color-muted);
                margin-bottom: var(--space-4);
                line-height: var(--leading-relaxed);
            }

            .mfa-spacing {
                margin-bottom: var(--space-4);
            }
        </style>
    </head>

    <body>
        <div class="login-card">
            <p class="login-logo">🔧 Dustin Auto Garage</p>
            <p class="login-subtitle">Log in op uw werkplaatsportaal</p>

            <div id="error-box" class="error-box" role="alert"></div>

            <form id="login-form" novalidate>
                <div class="form-group">
                    <label for="email">E-mailadres</label>
                    <input
                        id="email"
                        type="email"
                        name="email"
                        placeholder="jan@jansen.nl"
                        autocomplete="email"
                        required
                    />
                </div>

                <div class="form-group">
                    <label for="password">Wachtwoord</label>
                    <input
                        id="password"
                        type="password"
                        name="password"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    />
                </div>

                <button type="submit" id="submit-btn" class="btn-login"
                    >Inloggen</button
                >
            </form>

            <!-- MFA stap — verborgen tot backend mfa_required stuurt -->
            <div id="mfa-step" style="display:none">
                <p class="mfa-hint">
                    Voor uw veiligheid is verificatie vereist.<br />
                    Klik op de knop om een code naar uw e-mailadres te sturen.
                </p>
                <button
                    type="button"
                    id="send-code-btn"
                    class="btn-login mfa-spacing"
                >
                    Stuur verificatiecode
                </button>

                <div class="form-group">
                    <label for="mfa-code">Verificatiecode</label>
                    <input
                        id="mfa-code"
                        type="text"
                        inputmode="numeric"
                        maxlength="6"
                        placeholder="123456"
                        autocomplete="one-time-code"
                    />
                </div>

                <button type="button" id="mfa-submit-btn" class="btn-login"
                    >Verifiëren</button
                >
            </div>
        </div>

        <script is:inline>
            // ── State ────────────────────────────────────────────────────────
            let mfaRequired = false;

            // ── Elements ─────────────────────────────────────────────────────
            const form = document.getElementById("login-form");
            const btn = document.getElementById("submit-btn");
            const err = document.getElementById("error-box");
            const mfaStep = document.getElementById("mfa-step");
            const mfaCode = document.getElementById("mfa-code");
            const sendBtn = document.getElementById("send-code-btn");
            const mfaBtn = document.getElementById("mfa-submit-btn");

            // ── Stap 1: Inloggen (e-mail + wachtwoord) ───────────────────────
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                if (mfaRequired) return;

                btn.disabled = true;
                btn.textContent = "Bezig…";
                err.classList.remove("visible");

                const email = document.getElementById("email").value.trim();
                const password = document.getElementById("password").value;

                try {
                    const res = await fetch("/api/auth/login", {
                        method: "POST",
                        credentials: "include",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ email, password }),
                    });

                    const data = await res.json().catch(() => ({}));

                    if (!res.ok) {
                        err.textContent =
                            data.error ?? "Ongeldige inloggegevens.";
                        err.classList.add("visible");
                        return;
                    }

                    if (data.mfa_required) {
                        mfaRequired = true;
                        form.style.display = "none";
                        mfaStep.style.display = "block";
                        return;
                    }

                    window.location.href = "/dashboard";
                } catch {
                    err.textContent =
                        "Verbinding mislukt. Controleer uw internet.";
                    err.classList.add("visible");
                } finally {
                    btn.disabled = false;
                    btn.textContent = "Inloggen";
                }
            });

            // ── Stap 2: Verstuur e-mail verificatiecode ───────────────────────
            sendBtn.addEventListener("click", async () => {
                sendBtn.disabled = true;
                sendBtn.textContent = "Versturen…";
                err.classList.remove("visible");

                try {
                    const res = await fetch("/api/auth/mfa/send-email", {
                        method: "POST",
                        credentials: "include",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({}),
                    });

                    if (res.ok) {
                        sendBtn.textContent = "✓ Code verstuurd";
                        mfaCode.focus();
                    } else {
                        const d = await res.json().catch(() => ({}));
                        err.textContent = d.error ?? "Kon geen code versturen.";
                        err.classList.add("visible");
                        sendBtn.disabled = false;
                        sendBtn.textContent = "Stuur nieuwe code";
                    }
                } catch {
                    err.textContent = "Verbinding mislukt.";
                    err.classList.add("visible");
                    sendBtn.disabled = false;
                    sendBtn.textContent = "Probeer opnieuw";
                }
            });

            // ── Stap 3: Verifieer de code ─────────────────────────────────────
            mfaBtn.addEventListener("click", async () => {
                const code = mfaCode.value.trim();
                if (!code) {
                    mfaCode.focus();
                    return;
                }

                mfaBtn.disabled = true;
                mfaBtn.textContent = "Verifiëren…";
                err.classList.remove("visible");

                try {
                    const res = await fetch("/api/auth/mfa/verify", {
                        method: "POST",
                        credentials: "include",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ code }),
                    });

                    if (res.ok) {
                        window.location.href = "/dashboard";
                    } else {
                        const d = await res.json().catch(() => ({}));
                        err.textContent =
                            d.error ?? "Ongeldige code. Probeer opnieuw.";
                        err.classList.add("visible");
                        mfaBtn.disabled = false;
                        mfaBtn.textContent = "Verifiëren";
                    }
                } catch {
                    err.textContent = "Verbinding mislukt.";
                    err.classList.add("visible");
                    mfaBtn.disabled = false;
                    mfaBtn.textContent = "Verifiëren";
                }
            });
        </script>
    </body>
</html>
