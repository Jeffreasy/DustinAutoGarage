---
/**
 * src/pages/werkplaats.astro
 *
 * Werkplaatsbord — digitaal whiteboard van de garage.
 * Navigatie en uitloggen zitten in BaseLayout — geen dubbele header.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import WerkplaatsBordIsland from "../components/werkplaats/WerkplaatsBordIsland";

const user = Astro.locals.user ?? null;
if (!user) return Astro.redirect("/login?reden=sessie_verlopen");
---

<BaseLayout
    title="Werkplaatsbord — Dustin Auto Garage"
    description="Digitaal werkplaatsbord — real-time overzicht van alle auto's en bruggen."
>
    <!--
        BELANGRIJK: overflow-x moet NIET hidden zijn op deze wrapper — anders
        kan het horizontaal scrollende Kanban-bord niet scrollen op mobiel/tablet.
        De pagina-kop krijgt padding, het bord krijgt volledige breedte.
    -->
    <div class="werkplaats-pagina">
        <!-- Pagina-kop: alleen tekst, geen nav (zit in BaseLayout) -->
        <div class="werkplaats-kop">
            <h1>🏭 Werkplaatsbord</h1>
            <p class="kop-subtitel">
                Real-time — alle wijzigingen zijn direct zichtbaar voor iedereen
                in de garage
            </p>
        </div>

        <!-- React Island: LaventeConvexProvider + WerkplaatsBord in één React root -->
        <WerkplaatsBordIsland client:only="react" />
    </div>
</BaseLayout>

<style>
    /* Pagina wrapper — GEEN overflow hidden, anders scroll kapot op tablet */
    .werkplaats-pagina {
        padding: var(--space-5) var(--space-5) 0;
        max-width: 100%; /* Bord mag verder gaan dan de container-max */
        box-sizing: border-box;
    }

    /* Op bredere schermen een max container voor de kop, bord zelf scrollt */
    @media (min-width: 1280px) {
        .werkplaats-pagina {
            padding: var(--space-6) var(--space-6) 0;
        }
    }

    /* Pagina-kop */
    .werkplaats-kop {
        max-width: 1280px;
        margin: 0 auto var(--space-4);
    }

    .werkplaats-kop h1 {
        font-size: var(--text-2xl);
        font-weight: var(--weight-bold);
        color: var(--color-heading);
        margin: 0 0 var(--space-1);
        line-height: var(--leading-tight);
    }

    .kop-subtitel {
        font-size: var(--text-sm);
        color: var(--color-muted);
        margin: 0;
    }

    /* Op mobiel iets compactere kop */
    @media (max-width: 640px) {
        .werkplaats-pagina {
            padding: var(--space-4) var(--space-3) 0;
        }
        .werkplaats-kop h1 {
            font-size: var(--text-xl);
        }
    }
</style>
