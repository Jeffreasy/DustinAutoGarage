---
/**
 * src/pages/werkplaats.astro
 *
 * Werkplaatsbord — digitaal whiteboard van de garage.
 * Navigatie en uitloggen zitten in BaseLayout — geen dubbele header.
 *
 * Toegangslogica:
 *   Alle ingelogde medewerkers → toegang
 *   Niet ingelogd             → redirect naar /login
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import WerkplaatsBordIsland from "../components/WerkplaatsBordIsland";

const user = Astro.locals.user ?? null;
if (!user) return Astro.redirect("/login?reden=sessie_verlopen");
---

<BaseLayout
    title="Werkplaatsbord — Dustin Auto Garage"
    description="Digitaal werkplaatsbord — real-time overzicht van alle auto's en bruggen."
>
    <div class="werkplaats-wrapper">
        <!-- Pagina-kop -->
        <div class="page-kop">
            <h1>Werkplaatsbord</h1>
            <p class="pagina-ondertitel">
                Real-time overzicht van alle werkorders en bruggen
            </p>
        </div>

        <!-- React Island: LaventeConvexProvider + WerkplaatsBord in één React root -->
        <WerkplaatsBordIsland client:only="react" />
    </div>
</BaseLayout>

<style>
    .werkplaats-wrapper {
        padding: var(--space-5) var(--space-5) 0;
        max-width: var(--container-max, 1280px);
        margin: 0 auto;
        /* Bord heeft eigen horizontale scroll */
        overflow-x: hidden;
    }

    .page-kop {
        margin-bottom: var(--space-5);
    }

    .page-kop h1 {
        font-size: var(--text-2xl);
        font-weight: var(--weight-bold);
        color: var(--color-heading);
        margin: 0 0 var(--space-1);
        line-height: var(--leading-tight);
    }

    .pagina-ondertitel {
        font-size: var(--text-sm);
        color: var(--color-muted);
        margin: 0;
    }
</style>
