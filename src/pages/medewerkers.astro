---
/**
 * src/pages/medewerkers.astro
 *
 * Medewerkers Beheer — server-side bewaakt (editor+ identity rol).
 * Navigatie en uitloggen zitten in BaseLayout — geen dubbele header.
 *
 * Toegangslogica:
 *   LaventeCare identity "editor" of "admin" → toegang
 *   LaventeCare identity "user" of "viewer"  → redirect naar /dashboard
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import MedewerkersIsland from "../components/medewerkers/MedewerkersIsland";

const user = Astro.locals.user ?? null;
if (!user) return Astro.redirect("/login?reden=sessie_verlopen");

const heeftToegang = user.role === "editor" || user.role === "admin";
if (!heeftToegang)
    return Astro.redirect("/dashboard?reden=onvoldoende_rechten");
---

<BaseLayout
    title="Medewerkers — Dustin Auto Garage"
    description="Beheer medewerkers, uitnodigingen en domeinrollen."
>
    <div class="page-content">
        <!-- Pagina-kop -->
        <div class="page-kop">
            <h1>Medewerkers</h1>
            <p class="pagina-ondertitel">
                Beheer garage-medewerkers en hun domein-rollen
            </p>
        </div>

        <!-- React Island: real-time medewerkers lijst + invite flow -->
        <MedewerkersIsland client:only="react" identityRole={user.role} />
    </div>
</BaseLayout>

<style>
    .page-content {
        padding: var(--space-6) var(--space-5);
        max-width: var(--container-max, 1280px);
        margin: 0 auto;
    }

    .page-kop {
        margin-bottom: var(--space-6);
    }

    .page-kop h1 {
        font-size: var(--text-2xl);
        font-weight: var(--weight-bold);
        color: var(--color-heading);
        margin: 0 0 var(--space-1);
        line-height: var(--leading-tight);
    }

    .pagina-ondertitel {
        font-size: var(--text-sm);
        color: var(--color-muted);
        margin: 0;
    }
</style>
