---
/**
 * src/pages/dashboard.astro
 *
 * Dashboard pagina — server-side geguard, client-side Convex provider.
 *
 * Beveiligingsstroom:
 *   1. Astro Middleware valideert de HttpOnly session cookie via
 *      een server-to-server aanroep naar de LaventeCare /auth/me endpoint.
 *      Als de cookie ontbreekt of verlopen is → redirect naar /login.
 *   2. De React Island `LaventeConvexProvider` haalt client-side het RS256 JWT
 *      op via GET /api/v1/auth/token (credentials: "include") en geeft dit
 *      door aan de Convex client.
 *   3. Alle Convex queries zijn tenant-geïsoleerd via tokenIdentifier.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardIsland from "../components/DashboardIsland";

// ── Server-Side Guard ──────────────────────────────────────────────────────
// Haal de huidige gebruiker op uit context.locals (gevuld door de Astro Middleware).
// Als middleware niet geconfigureerd is, val terug op een directe /auth/me check.
const user = Astro.locals.user ?? null;

if (!user) {
  return Astro.redirect("/login?reden=sessie_verlopen");
}
---

<BaseLayout
  title="Dashboard — Auto Garage"
  description="Beheer uw klanten, voertuigen en onderhoudshistorie."
>
  <!-- Dashboard header -->
  <header class="dashboard-header">
    <div class="container">
      <div class="header-content">
        <div>
          <h1>Dashboard</h1>
          <p class="header-subtitle">
            Welkom terug, <strong>{user.full_name ?? user.email}</strong>
            <span class="identity-badge">{user.role}</span>
          </p>
        </div>
        <nav class="header-nav">
          {
            (user.role === "editor" || user.role === "admin") && (
              <a href="/medewerkers" class="btn btn-ghost btn-sm">
                👥 Medewerkers
              </a>
            )
          }
          <a href="/logout" class="btn btn-ghost btn-sm">Uitloggen</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- React Island: satellite token flow + Convex provider -->
  <!--
    `client:load` zorgt dat de Island direct na page load hydrateert.
    De provider fetcht intern het RS256 JWT en start de Convex sessie.
  -->
  <main class="container dashboard-main">
    <!-- DashboardIsland = LaventeConvexProvider + VoertuigenDashboard in één React root.
         client:only="react" = geen SSR, voorkomt ConvexProvider context fout. -->
    <DashboardIsland client:only="react" />
  </main>
</BaseLayout>

<style>
  /* ── Header ─────────────────────────────────────────────────────────────── */
  .dashboard-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-5) 0;
    margin-bottom: var(--space-6);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .dashboard-header h1 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-heading);
    margin: 0;
    line-height: var(--leading-tight);
  }

  .header-subtitle {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-1);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .identity-badge {
    display: inline-flex;
    align-items: center;
    padding: 1px 8px;
    border-radius: var(--radius-full, 9999px);
    font-size: var(--text-xs);
    font-weight: 600;
    background: var(--color-primary-muted, rgba(13, 122, 95, 0.12));
    color: var(--color-primary, #0d7a5f);
    letter-spacing: 0.03em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ── Main ────────────────────────────────────────────────────────────────── */
  .dashboard-main {
    padding-block: var(--space-6);
  }
</style>
