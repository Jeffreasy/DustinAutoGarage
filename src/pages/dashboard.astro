---
/**
 * src/pages/dashboard.astro
 *
 * Dashboard hoofdpagina. Server-side bewaakt.
 * Navigatie en uitloggen zitten in BaseLayout — hier geen dubbele header.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardIsland from "../components/dashboard/DashboardIsland";

const user = Astro.locals.user ?? null;
if (!user) return Astro.redirect("/login?reden=sessie_verlopen");
---

<BaseLayout
  title="Dashboard — Auto Garage"
  description="Beheer uw klanten, voertuigen en onderhoudshistorie."
>
  <div class="page-content">
    <!-- Pagina-kop -->
    <div class="page-kop">
      <h1>Dashboard</h1>
      <p class="pagina-ondertitel">
        Welkom terug, <strong>{user.full_name ?? user.email}</strong>
        <span class="rol-badge">{user.role}</span>
      </p>
    </div>

    <!-- React Island: satellite token flow + Convex provider + voertuigen-dashboard -->
    <DashboardIsland client:only="react" />
  </div>
</BaseLayout>

<style>
  .page-content {
    padding: var(--space-6) var(--space-5);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .page-kop {
    margin-bottom: var(--space-6);
  }

  .page-kop h1 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-heading);
    margin: 0 0 var(--space-1);
    line-height: var(--leading-tight);
  }

  .pagina-ondertitel {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .rol-badge {
    display: inline-block;
    padding: var(--space-px) var(--space-2);
    border-radius: var(--radius-full);
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-muted);
    text-transform: capitalize;
  }
</style>
