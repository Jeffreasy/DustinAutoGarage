---
/**
 * src/pages/dashboard.astro
 *
 * Dashboard pagina — server-side geguard, client-side Convex provider.
 *
 * Beveiligingsstroom:
 *   1. Astro Middleware valideert de HttpOnly session cookie via
 *      een server-to-server aanroep naar de LaventeCare /auth/me endpoint.
 *      Als de cookie ontbreekt of verlopen is → redirect naar /login.
 *   2. De React Island `LaventeConvexProvider` haalt client-side het RS256 JWT
 *      op via GET /api/v1/auth/token (credentials: "include") en geeft dit
 *      door aan de Convex client.
 *   3. Alle Convex queries zijn tenant-geïsoleerd via tokenIdentifier.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { LaventeConvexProvider } from "../components/LaventeConvexProvider";
import VoertuigenDashboard from "../components/VoertuigenDashboard";

// ── Server-Side Guard ──────────────────────────────────────────────────────
// Haal de huidige gebruiker op uit context.locals (gevuld door de Astro Middleware).
// Als middleware niet geconfigureerd is, val terug op een directe /auth/me check.
const user = Astro.locals.user ?? null;

if (!user) {
  return Astro.redirect("/login?reden=sessie_verlopen");
}
---

<BaseLayout title="Dashboard — Auto Garage" description="Beheer uw klanten, voertuigen en onderhoudshistorie.">

  <!-- Dashboard header -->
  <header class="dashboard-header">
    <div class="container">
      <div class="header-content">
        <div>
          <h1>Dashboard</h1>
          <p class="header-subtitle">
            Welkom terug, <strong>{user.full_name ?? user.email}</strong>
          </p>
        </div>
        <a href="/logout" class="btn-logout">Uitloggen</a>
      </div>
    </div>
  </header>

  <!-- React Island: satellite token flow + Convex provider -->
  <!--
    `client:load` zorgt dat de Island direct na page load hydrateert.
    De provider fetcht intern het RS256 JWT en start de Convex sessie.
  -->
  <main class="container dashboard-main">
    <LaventeConvexProvider client:load>
      <!--
        VoertuigenDashboard gebruikt `api.voertuigen.list` en
        `api.voertuigen.getBijnaVerlopenApk` intern via useQuery().
        Zolang de provider laadt, toont het component een eigen skeleton.
      -->
      <VoertuigenDashboard client:load />
    </LaventeConvexProvider>
  </main>

</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  .dashboard-header {
    background: var(--color-surface, #0f172a);
    border-bottom: 1px solid var(--color-border, #1e293b);
    padding: 1.25rem 0;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-heading, #f8fafc);
    margin: 0;
  }

  .header-subtitle {
    font-size: 0.875rem;
    color: var(--color-muted, #94a3b8);
    margin: 0.25rem 0 0;
  }

  .btn-logout {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    background: transparent;
    color: var(--color-muted, #94a3b8);
    border: 1px solid var(--color-border, #334155);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .btn-logout:hover {
    color: var(--color-error-text, #f87171);
    border-color: var(--color-error-text, #f87171);
  }

  /* ── Main ────────────────────────────────────────────────────────────────── */
  .dashboard-main {
    padding: 2rem 1.5rem;
  }
</style>
