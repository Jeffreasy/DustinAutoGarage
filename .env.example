# ── Astro lokale omgeving — Dustin Auto Garage ──────────────────────────────
# Kopieer dit bestand naar .env.local voor lokale development.
# Vercel: voer deze vars in via Project → Settings → Environment Variables.

# ────────────────────────────────────────────────────────────────────────────
# CONVEX
# ────────────────────────────────────────────────────────────────────────────

# Jouw Convex Cloud deployment URL (te vinden in het Convex Dashboard)
PUBLIC_CONVEX_URL=https://rosy-seahorse-403.eu-west-1.convex.cloud

# Convex deployment naam (lokaal: dev:..., productie: prod:...)
# Vercel: gebruik prod:rosy-seahorse-403
CONVEX_DEPLOYMENT=dev:rosy-seahorse-403

# Convex site URL (gebruikt door webhooks en scheduled functions)
CONVEX_SITE_URL=https://rosy-seahorse-403.eu-west-1.convex.site

# Convex Deploy Key — ALLEEN nodig voor Vercel CI build
# Ophalen via: Convex Dashboard → Settings → Deploy Keys → New deployment key
# LET OP: Houd dit geheim. Niet committen.
CONVEX_DEPLOY_KEY=

# ────────────────────────────────────────────────────────────────────────────
# LAVENTECARE AUTH BACKEND
# ────────────────────────────────────────────────────────────────────────────

# Server-side URL (gebruikt door Astro Middleware voor /auth/me — geen PUBLIC_ prefix)
# Vercel Serverless Functions kunnen dit bereiken zonder CORS-beperkingen
API_URL=https://auth.laventecare.nl

# Client-side URL (gebruikt door LaventeConvexProvider voor satellite token fetch)
PUBLIC_API_URL=https://auth.laventecare.nl

# ────────────────────────────────────────────────────────────────────────────
# TENANT IDENTIFICATIE
# ────────────────────────────────────────────────────────────────────────────

# Server-side Tenant UUID (Astro Middleware + BFF proxy → X-Tenant-ID header)
TENANT_ID=jouw-tenant-uuid-hier

# Client-side (indien nodig in browser context)
PUBLIC_TENANT_ID=jouw-tenant-uuid-hier
